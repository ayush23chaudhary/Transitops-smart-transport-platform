datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../backend/node_modules/.prisma/client"
}

enum UserRole {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseCategory {
  TOLL
  PARKING
  REPAIR
  MAINTENANCE
  INSURANCE
  OTHER
}

model User {
  id           String              @id @default(uuid()) @db.Uuid
  name         String
  email        String              @unique
  passwordHash String
  role         UserRole
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  trips        Trip[]
  maintenance  MaintenanceRecord[]
  fuelLogs     FuelLog[]
  expenses     Expense[]

  @@index([email])
}

model Vehicle {
  id                 String              @id @default(uuid()) @db.Uuid
  registrationNumber String              @unique
  name               String
  type               String
  maxLoadCapacity    Decimal             @db.Decimal(10, 2)
  odometer           Decimal             @default(0.00) @db.Decimal(10, 2)
  acquisitionCost    Decimal             @db.Decimal(10, 2)
  status             VehicleStatus       @default(AVAILABLE)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  trips              Trip[]
  maintenance        MaintenanceRecord[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([status])
  @@index([registrationNumber])
}

model Driver {
  id                 String       @id @default(uuid()) @db.Uuid
  name               String
  email              String       @unique
  phone              String
  licenseNumber      String       @unique
  licenseCategory    String
  licenseExpiryDate  DateTime
  safetyScore        Decimal      @default(10.00) @db.Decimal(4, 2)
  status             DriverStatus @default(AVAILABLE)
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  trips              Trip[]

  @@index([status])
  @@index([email])
  @@index([licenseNumber])
}

model Trip {
  id              String       @id @default(uuid()) @db.Uuid
  tripNumber      String       @unique
  source          String
  destination     String
  vehicleId       String       @db.Uuid
  vehicle         Vehicle      @relation(fields: [vehicleId], references: [id])
  driverId        String       @db.Uuid
  driver          Driver       @relation(fields: [driverId], references: [id])
  cargoWeight     Decimal      @db.Decimal(10, 2)
  plannedDistance Decimal      @db.Decimal(10, 2)
  actualDistance  Decimal?     @db.Decimal(10, 2)
  startOdometer   Decimal?     @db.Decimal(10, 2)
  endOdometer     Decimal?     @db.Decimal(10, 2)
  revenue         Decimal?     @db.Decimal(10, 2)
  status          TripStatus   @default(DRAFT)
  scheduledAt     DateTime
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdById     String       @db.Uuid
  creator         User         @relation(fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([tripNumber])
  @@index([scheduledAt])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceRecord {
  id              String            @id @default(uuid()) @db.Uuid
  vehicleId       String            @db.Uuid
  vehicle         Vehicle           @relation(fields: [vehicleId], references: [id])
  maintenanceType String
  description     String            @db.Text
  cost            Decimal           @db.Decimal(10, 2)
  status          MaintenanceStatus
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdById     String            @db.Uuid
  creator         User              @relation(fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([vehicleId])
}

model FuelLog {
  id              String    @id @default(uuid()) @db.Uuid
  vehicleId       String    @db.Uuid
  vehicle         Vehicle   @relation(fields: [vehicleId], references: [id])
  tripId          String?   @db.Uuid
  trip            Trip?     @relation(fields: [tripId], references: [id])
  liters          Decimal   @db.Decimal(10, 2)
  cost            Decimal   @db.Decimal(10, 2)
  odometerReading Decimal   @db.Decimal(10, 2)
  recordedAt      DateTime
  createdById     String    @db.Uuid
  creator         User      @relation(fields: [createdById], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([vehicleId])
  @@index([tripId])
  @@index([recordedAt])
}

model Expense {
  id          String          @id @default(uuid()) @db.Uuid
  vehicleId   String?         @db.Uuid
  vehicle     Vehicle?        @relation(fields: [vehicleId], references: [id])
  tripId      String?         @db.Uuid
  trip        Trip?           @relation(fields: [tripId], references: [id])
  category    ExpenseCategory
  amount      Decimal         @db.Decimal(10, 2)
  description String
  expenseDate DateTime
  createdById String          @db.Uuid
  creator     User            @relation(fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([vehicleId])
  @@index([tripId])
  @@index([expenseDate])
}

model OrganizationSettings {
  id           String   @id @default(uuid()) @db.Uuid
  depotName    String   @default("TransitOps Default Depot")
  currencyCode String   @default("USD")
  distanceUnit String   @default("km")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
